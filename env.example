// ============================================================
// GEDE4 — Momentum · Volatility · Volume Intelligence Suite
// ============================================================
// Agent     : GEDE4 (Momentum & Volatility Specialist)
// Team      : CryptoLwa.io · Brigitte's Swap
// Reports to: Lasirèn (Master Trading Agent — cryptolwa.io)
// Pine      : v6 (clean, errors fixed, deployable)
//
// PURPOSE:
//   A single, self-contained TradingView Pine v6 indicator that
//   replicates GEDE4's full analytical brain:
//     • Momentum scoring (RSI, MACD, Stochastic, CCI, ROC, Williams %R)
//     • Volatility engine (Bollinger Bands, ATR, Keltner, BB Squeeze)
//     • Volume intelligence (OBV, CVD proxy, MFI, VWAP)
//     • Support/Resistance (Auto-Fib, Pivot Points, S/R zones)
//     • Confluence-gated entry / stop / R:R targets
//     • Capital preservation rule on every signal
//     • Webhook-ready alerts for Lasirèn bridge
//
// FIXES vs v5:
//   • //@version=6
//   • Fixed precedence bug:
//       `not long_confluence[1] >= n` → `not (long_confluence[1] >= n)`
//   • `text_font_face` → `text_font_family` (correct Pine param name)
//   • Zero-division guards on risk / position-size math
//   • `lookahead=barmerge.lookahead_off` on every HTF security call
//   • Fib lines bounded by bar_index, drawn once on last bar
//   • Unused vars removed (squeeze_bars, f_col, c_bg, fib_names)
//   • `alertcondition` lifted to top-level (gated by i_alertsOn)
//   • `alert()` dynamic webhook payloads added for Lasirèn /signal
//   • Explicit type annotations where v6 is stricter
//
// USAGE: Add to any crypto chart. All inputs are configurable.
//   Set TradingView alert action to "Webhook URL" pointing at your
//   Lasirèn bridge /signal endpoint, alert message = {{strategy.order.alert_message}}
//   (or just enable "Any alert() function call" — the alert() lines
//   below fire the structured JSON automatically).
//
// Capital preservation comes before profit.
// ============================================================

//@version=6
indicator(
     title              = "GEDE4 — Momentum·Volatility·Volume Intelligence [CryptoLwa]",
     shorttitle         = "GEDE4·MVV",
     overlay            = true,
     max_bars_back      = 500,
     max_lines_count    = 50,
     max_labels_count   = 50,
     max_boxes_count    = 50)

// ─────────────────────────────────────────────────────────────
// SECTION 0 — INPUT GROUPS
// ─────────────────────────────────────────────────────────────

// ── Risk Management ─────────────────────────────────────────
var string g_risk = "⚖️  Risk Management"
i_riskPct          = input.float(1.5,   "Risk per Trade (%)",          minval=0.1, maxval=5.0,  step=0.1, group=g_risk, tooltip="GEDE4 never risks more than this % of account per trade.")
i_minRR            = input.float(2.0,   "Min Risk:Reward Ratio",       minval=1.0, maxval=10.0, step=0.5, group=g_risk)
i_maxPortfolioHeat = input.float(8.0,   "Max Portfolio Heat (%)",      minval=1.0, maxval=20.0, step=0.5, group=g_risk)
i_ddStopPct        = input.float(15.0,  "Portfolio DD Stop (%)",       minval=5.0, maxval=30.0, step=1.0, group=g_risk)
i_accountSize      = input.float(10000, "Account Size (USD)",          minval=100, group=g_risk)

// ── Momentum ────────────────────────────────────────────────
var string g_mom = "🚀  Momentum Indicators"
i_rsiLen      = input.int(14,    "RSI Length",            group=g_mom)
i_rsiOB       = input.int(70,    "RSI Overbought",        group=g_mom)
i_rsiOS       = input.int(30,    "RSI Oversold",          group=g_mom)
i_macdFast    = input.int(12,    "MACD Fast",             group=g_mom)
i_macdSlow    = input.int(26,    "MACD Slow",             group=g_mom)
i_macdSig     = input.int(9,     "MACD Signal",           group=g_mom)
i_stochK      = input.int(14,    "Stoch %K",              group=g_mom)
i_stochD      = input.int(3,     "Stoch %D",              group=g_mom)
i_stochSmooth = input.int(3,     "Stoch Smooth",          group=g_mom)
i_cciLen      = input.int(20,    "CCI Length",            group=g_mom)
i_rocLen      = input.int(12,    "ROC Length",            group=g_mom)
i_willLen     = input.int(14,    "Williams %R Length",    group=g_mom)

// ── Volatility ──────────────────────────────────────────────
var string g_vol = "⚡  Volatility Engine"
i_bbLen       = input.int(20,    "BB Length",                  group=g_vol)
i_bbMult      = input.float(2.0, "BB Std Dev Multiplier",      group=g_vol)
i_atrLen      = input.int(14,    "ATR Length",                 group=g_vol)
i_atrStopMult = input.float(2.0, "ATR Stop Multiplier",        group=g_vol, tooltip="Stop = ATR × this value from entry.")
i_keltLen     = input.int(20,    "Keltner Length",             group=g_vol)
i_keltMult    = input.float(1.5, "Keltner ATR Multiplier",     group=g_vol)

// ── Volume ──────────────────────────────────────────────────
var string g_volu = "📊  Volume Intelligence"
i_mfiLen         = input.int(14,    "MFI Length",                   group=g_volu)
i_obvSmoothLen   = input.int(5,     "OBV Smooth Length",            group=g_volu)
i_vwapSource     = input.source(hlc3, "VWAP Source",                group=g_volu)
i_volAvgLen      = input.int(20,    "Volume Avg Length",            group=g_volu)
i_volSpikeThresh = input.float(1.5, "Volume Spike Threshold (×avg)",group=g_volu)

// ── Support & Resistance ────────────────────────────────────
var string g_sr = "📍  Support & Resistance"
i_pivotLen    = input.int(10,    "Pivot Detection Length",   group=g_sr)
i_showFib     = input.bool(true, "Show Auto-Fibonacci",      group=g_sr)
i_showPivots  = input.bool(true, "Show Daily Pivot Points",  group=g_sr)
i_fibLookback = input.int(100,   "Fibonacci Swing Lookback", group=g_sr)

// ── Signal Filter ───────────────────────────────────────────
var string g_sig = "🎯  Signal Settings"
i_minConfluence = input.int(4,     "Min Confluence Score (1–8)",       minval=1, maxval=8, group=g_sig, tooltip="How many independent signals must agree before GEDE4 fires.")
i_showLabels    = input.bool(true, "Show Trade Labels",                group=g_sig)
i_showTable     = input.bool(true, "Show GEDE4 Intelligence Panel",    group=g_sig)
i_htfTrend      = input.timeframe("D", "Higher Timeframe (Trend Bias)", group=g_sig)
i_alertsOn      = input.bool(true, "Enable Alerts",                    group=g_sig)

// ── Display ─────────────────────────────────────────────────
var string g_disp = "🎨  Display"
i_showBB      = input.bool(true, "Show Bollinger Bands",     group=g_disp)
i_showKeltner = input.bool(true, "Show Keltner Channel",     group=g_disp)
i_showVwap    = input.bool(true, "Show VWAP",                group=g_disp)
i_showSRZones = input.bool(true, "Show S/R Zone Background", group=g_disp)

// ─────────────────────────────────────────────────────────────
// SECTION 1 — MOMENTUM
// ─────────────────────────────────────────────────────────────

rsi          = ta.rsi(close, i_rsiLen)
rsi_bull     = rsi < i_rsiOS
rsi_bear     = rsi > i_rsiOB

rsi_prevHigh = ta.highest(rsi, 14)[1]
rsi_prevLow  = ta.lowest(rsi, 14)[1]
price_prevH  = ta.highest(high, 14)[1]
price_prevL  = ta.lowest(low, 14)[1]
bull_div_rsi = (close < price_prevL) and (rsi > rsi_prevLow)
bear_div_rsi = (close > price_prevH) and (rsi < rsi_prevHigh)

[macdLine, signalLine, macdHist] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSig)
macd_bull         = ta.crossover(macdLine, signalLine)
macd_bear         = ta.crossunder(macdLine, signalLine)
macd_hist_rising  = macdHist > macdHist[1] and macdHist > 0
macd_hist_falling = macdHist < macdHist[1] and macdHist < 0

stoch_k    = ta.sma(ta.stoch(close, high, low, i_stochK), i_stochSmooth)
stoch_d    = ta.sma(stoch_k, i_stochD)
stoch_bull = ta.crossover(stoch_k, stoch_d)  and stoch_k < 20
stoch_bear = ta.crossunder(stoch_k, stoch_d) and stoch_k > 80

cci      = ta.cci(close, i_cciLen)
cci_bull = cci < -100
cci_bear = cci > 100

roc      = ta.roc(close, i_rocLen)
roc_bull = roc > 0 and roc > roc[1]
roc_bear = roc < 0 and roc < roc[1]

willR     = ta.wpr(i_willLen)
will_bull = willR < -80
will_bear = willR > -20

// Composite Momentum Score (−6 … +6) — recomputed every bar
int mom_score = 0
mom_score := mom_score + (rsi_bull ? 1 : rsi_bear ? -1 : 0)
mom_score := mom_score + ((macd_bull or macd_hist_rising) ? 1 : (macd_bear or macd_hist_falling) ? -1 : 0)
mom_score := mom_score + (stoch_bull ? 1 : stoch_bear ? -1 : 0)
mom_score := mom_score + (cci_bull   ? 1 : cci_bear   ? -1 : 0)
mom_score := mom_score + (roc_bull   ? 1 : roc_bear   ? -1 : 0)
mom_score := mom_score + (will_bull  ? 1 : will_bear  ? -1 : 0)

// ─────────────────────────────────────────────────────────────
// SECTION 2 — VOLATILITY ENGINE
// ─────────────────────────────────────────────────────────────

bb_basis     = ta.sma(close, i_bbLen)
bb_dev       = i_bbMult * ta.stdev(close, i_bbLen)
bb_upper     = bb_basis + bb_dev
bb_lower     = bb_basis - bb_dev
bb_width     = bb_basis != 0 ? (bb_upper - bb_lower) / bb_basis : 0.0
bb_width_avg = ta.sma(bb_width, 50)

atr_val = ta.atr(i_atrLen)

kelt_basis = ta.ema(close, i_keltLen)
kelt_range = atr_val * i_keltMult
kelt_upper = kelt_basis + kelt_range
kelt_lower = kelt_basis - kelt_range

// ── BB Squeeze (BB inside Keltner = coiled spring) ─────────
squeeze_on  = (bb_upper < kelt_upper) and (bb_lower > kelt_lower)
squeeze_off = (not squeeze_on) and squeeze_on[1]

var int squeeze_count = 0
squeeze_count := squeeze_on ? squeeze_count + 1 : 0
squeeze_strong = squeeze_count >= 8

// Band-touch reversals
touch_upper = high >= bb_upper and close < bb_upper
touch_lower = low  <= bb_lower and close > bb_lower

// Volatility percentile (0=very low, 100=extreme)
atr_highest = ta.highest(atr_val, 100)
atr_lowest  = ta.lowest(atr_val, 100)
vol_pctile  = atr_highest != atr_lowest ? (atr_val - atr_lowest) / (atr_highest - atr_lowest) * 100 : 50.0

vol_regime  = vol_pctile < 25 ? "QUIET" : vol_pctile < 50 ? "NORMAL" : vol_pctile < 75 ? "ELEVATED" : "EXTREME"

// ─────────────────────────────────────────────────────────────
// SECTION 3 — VOLUME INTELLIGENCE
// ─────────────────────────────────────────────────────────────

vol_avg   = ta.sma(volume, i_volAvgLen)
vol_spike = volume > vol_avg * i_volSpikeThresh
vol_dry   = volume < vol_avg * 0.5

obv      = ta.obv
obv_sma  = ta.sma(obv, i_obvSmoothLen)
obv_bull = obv > obv_sma
obv_bear = obv < obv_sma

obv_prev     = obv[i_obvSmoothLen]
bull_div_obv = close < close[i_obvSmoothLen] and obv > obv_prev
bear_div_obv = close > close[i_obvSmoothLen] and obv < obv_prev

mfi      = ta.mfi(hlc3, i_mfiLen)
mfi_bull = mfi < 20
mfi_bear = mfi > 80

vwap_val     = ta.vwap(i_vwapSource)
above_vwap   = close > vwap_val
below_vwap   = close < vwap_val
vwap_reclaim = close > vwap_val and close[1] < vwap_val
vwap_reject  = close < vwap_val and close[1] > vwap_val

// CVD proxy
candle_body      = close - open
candle_range_val = high - low
body_pct         = candle_range_val != 0 ? math.abs(candle_body) / candle_range_val : 0.5
delta_raw        = volume * (close > open ? body_pct : -body_pct)
var float cvd    = 0.0
cvd             := cvd + delta_raw
cvd_sma          = ta.sma(cvd, 14)
cvd_bull         = cvd > cvd_sma
cvd_bear         = cvd < cvd_sma

// Volume Score (−4 … +4)
int vol_score = 0
vol_score := vol_score + (obv_bull   ? 1 : obv_bear   ? -1 : 0)
vol_score := vol_score + (mfi_bull   ? 1 : mfi_bear   ? -1 : 0)
vol_score := vol_score + (above_vwap ? 1 : below_vwap ? -1 : 0)
vol_score := vol_score + (cvd_bull   ? 1 : cvd_bear   ? -1 : 0)

// ─────────────────────────────────────────────────────────────
// SECTION 4 — SUPPORT & RESISTANCE
// ─────────────────────────────────────────────────────────────

pivot_hi = ta.pivothigh(high, i_pivotLen, i_pivotLen)
pivot_lo = ta.pivotlow(low,   i_pivotLen, i_pivotLen)

// Daily pivot points
var float daily_high  = na
var float daily_low   = na
var float daily_close = na
if timeframe.change("D")
    daily_high  := high[1]
    daily_low   := low[1]
    daily_close := close[1]

pp = (daily_high + daily_low + daily_close) / 3
r1 = 2 * pp - daily_low
r2 = pp + (daily_high - daily_low)
r3 = daily_high + 2 * (pp - daily_low)
s1 = 2 * pp - daily_high
s2 = pp - (daily_high - daily_low)
s3 = daily_low - 2 * (daily_high - pp)

// Auto-Fibonacci
fib_high  = ta.highest(high, i_fibLookback)
fib_low   = ta.lowest(low,   i_fibLookback)
fib_range = fib_high - fib_low

fib_0    = fib_low
fib_236  = fib_low + fib_range * 0.236
fib_382  = fib_low + fib_range * 0.382
fib_500  = fib_low + fib_range * 0.500
fib_618  = fib_low + fib_range * 0.618
fib_786  = fib_low + fib_range * 0.786
fib_100  = fib_high
fib_1272 = fib_high + fib_range * 0.272
fib_1618 = fib_high + fib_range * 0.618

// Nearest Fib level scan
fib_levels = array.from(fib_0, fib_236, fib_382, fib_500, fib_618, fib_786, fib_100)

float nearest_fib  = fib_500
float nearest_dist = math.abs(close - fib_500)
for i = 0 to array.size(fib_levels) - 1
    d = math.abs(close - array.get(fib_levels, i))
    if d < nearest_dist
        nearest_dist := d
        nearest_fib  := array.get(fib_levels, i)

at_fib_level = close != 0 ? nearest_dist / close < 0.005 : false

// S/R proximity
at_pivot_support    = close != 0 and (math.abs(close - s1) / close < 0.005 or math.abs(close - s2) / close < 0.005)
at_pivot_resistance = close != 0 and (math.abs(close - r1) / close < 0.005 or math.abs(close - r2) / close < 0.005)

// ─────────────────────────────────────────────────────────────
// SECTION 5 — HIGHER TIMEFRAME TREND BIAS
// ─────────────────────────────────────────────────────────────

htf_close  = request.security(syminfo.tickerid, i_htfTrend, close,              lookahead=barmerge.lookahead_off)
htf_ema20  = request.security(syminfo.tickerid, i_htfTrend, ta.ema(close, 20),  lookahead=barmerge.lookahead_off)
htf_ema50  = request.security(syminfo.tickerid, i_htfTrend, ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
htf_ema200 = request.security(syminfo.tickerid, i_htfTrend, ta.ema(close, 200), lookahead=barmerge.lookahead_off)

htf_uptrend   = htf_close > htf_ema20 and htf_ema20 > htf_ema50 and htf_ema50 > htf_ema200
htf_downtrend = htf_close < htf_ema20 and htf_ema20 < htf_ema50 and htf_ema50 < htf_ema200
htf_neutral   = not htf_uptrend and not htf_downtrend
htf_bias      = htf_uptrend ? "BULL" : htf_downtrend ? "BEAR" : "NEUTRAL"

// ─────────────────────────────────────────────────────────────
// SECTION 6 — CONFLUENCE SCORING ENGINE
// ─────────────────────────────────────────────────────────────

long_c1 = htf_uptrend
long_c2 = mom_score >= 2
long_c3 = vol_score >= 1
long_c4 = touch_lower or at_fib_level or at_pivot_support
long_c5 = squeeze_off or (squeeze_strong and roc_bull)
long_c6 = vol_spike and (close > open)
long_c7 = bull_div_rsi or bull_div_obv
long_c8 = vwap_reclaim

long_confluence = (long_c1 ? 1 : 0) + (long_c2 ? 1 : 0) + (long_c3 ? 1 : 0) + (long_c4 ? 1 : 0) + (long_c5 ? 1 : 0) + (long_c6 ? 1 : 0) + (long_c7 ? 1 : 0) + (long_c8 ? 1 : 0)

short_c1 = htf_downtrend
short_c2 = mom_score <= -2
short_c3 = vol_score <= -1
short_c4 = touch_upper or at_fib_level or at_pivot_resistance
short_c5 = squeeze_off or (squeeze_strong and roc_bear)
short_c6 = vol_spike and (close < open)
short_c7 = bear_div_rsi or bear_div_obv
short_c8 = vwap_reject

short_confluence = (short_c1 ? 1 : 0) + (short_c2 ? 1 : 0) + (short_c3 ? 1 : 0) + (short_c4 ? 1 : 0) + (short_c5 ? 1 : 0) + (short_c6 ? 1 : 0) + (short_c7 ? 1 : 0) + (short_c8 ? 1 : 0)

// ─────────────────────────────────────────────────────────────
// SECTION 7 — TRADE SIGNAL GENERATION
// ─────────────────────────────────────────────────────────────

// Trigger only on transition into qualifying state (parens fix precedence)
long_signal  = long_confluence  >= i_minConfluence and not (long_confluence[1]  >= i_minConfluence)
short_signal = short_confluence >= i_minConfluence and not (short_confluence[1] >= i_minConfluence)

// ATR-based stops
long_stop  = long_signal  ? low  - (atr_val * i_atrStopMult) : na
short_stop = short_signal ? high + (atr_val * i_atrStopMult) : na

// Risk distances (na-safe)
long_risk  = not na(long_stop)  ? close - long_stop  : na
short_risk = not na(short_stop) ? short_stop - close : na

// Targets
long_t1  = not na(long_risk) ? close + long_risk * i_minRR        : na
long_t2  = not na(long_risk) ? close + long_risk * (i_minRR + 1)  : na
long_t3  = not na(long_risk) ? close + long_risk * (i_minRR + 3)  : na

short_t1 = not na(short_risk) ? close - short_risk * i_minRR        : na
short_t2 = not na(short_risk) ? close - short_risk * (i_minRR + 1)  : na
short_t3 = not na(short_risk) ? close - short_risk * (i_minRR + 3)  : na

// Position sizing with zero-division guard
risk_dollars = i_accountSize * (i_riskPct / 100)
long_size    = (long_signal  and not na(long_risk)  and long_risk  > 0) ? risk_dollars / long_risk  : na
short_size   = (short_signal and not na(short_risk) and short_risk > 0) ? risk_dollars / short_risk : na

// R:R sanity check
long_rr_valid  = long_signal  and not na(long_t1)  and (long_t1  > close)
short_rr_valid = short_signal and not na(short_t1) and (short_t1 < close)

// ─────────────────────────────────────────────────────────────
// SECTION 8 — VISUAL OVERLAYS
// ─────────────────────────────────────────────────────────────

bb_basis_plot = plot(i_showBB ? bb_basis : na, "BB Mid",   color=color.new(color.gray, 60), linewidth=1)
bb_upper_plot = plot(i_showBB ? bb_upper : na, "BB Upper", color=color.new(color.teal, 40), linewidth=1)
bb_lower_plot = plot(i_showBB ? bb_lower : na, "BB Lower", color=color.new(color.teal, 40), linewidth=1)
fill(bb_upper_plot, bb_lower_plot, color=color.new(color.teal, 95))

kelt_u_plot = plot(i_showKeltner ? kelt_upper : na, "Kelt Upper", color=color.new(color.orange, 55), linewidth=1, style=plot.style_linebr)
kelt_l_plot = plot(i_showKeltner ? kelt_lower : na, "Kelt Lower", color=color.new(color.orange, 55), linewidth=1, style=plot.style_linebr)
fill(kelt_u_plot, kelt_l_plot, color=color.new(color.orange, 96))

plot(i_showVwap ? vwap_val : na, "VWAP", color=color.new(color.yellow, 20), linewidth=2, style=plot.style_linebr)

bgcolor(squeeze_on  ? color.new(color.purple, 90) : na, title="Squeeze Background")
bgcolor(squeeze_off ? color.new(color.yellow, 75) : na, title="Squeeze Release")

bgcolor(i_showSRZones and at_pivot_support    ? color.new(color.green, 93) : na, title="Support Zone")
bgcolor(i_showSRZones and at_pivot_resistance ? color.new(color.red,   93) : na, title="Resistance Zone")

// Fib lines — drawn once on last bar, bounded by bar_index
var line fib_618_line = na
var line fib_382_line = na
var line fib_500_line = na
if i_showFib and barstate.islast
    line.delete(fib_618_line)
    line.delete(fib_382_line)
    line.delete(fib_500_line)
    x_left = math.max(0, bar_index - i_fibLookback)
    fib_618_line := line.new(x_left, fib_618, bar_index + 10, fib_618, color=color.new(color.yellow, 30), width=1, style=line.style_dashed)
    fib_382_line := line.new(x_left, fib_382, bar_index + 10, fib_382, color=color.new(color.yellow, 50), width=1, style=line.style_dashed)
    fib_500_line := line.new(x_left, fib_500, bar_index + 10, fib_500, color=color.new(color.yellow, 40), width=1, style=line.style_dotted)

plotshape(i_showPivots and not na(pivot_hi), "Pivot High", shape.triangledown, location.abovebar, color.new(color.red,  40), size=size.tiny)
plotshape(i_showPivots and not na(pivot_lo), "Pivot Low",  shape.triangleup,   location.belowbar, color.new(color.lime, 40), size=size.tiny)

// ─────────────────────────────────────────────────────────────
// SECTION 9 — SIGNAL LABELS
// ─────────────────────────────────────────────────────────────

if i_showLabels and long_rr_valid
    string ltxt = "🟢 GEDE4 LONG\n"
    ltxt := ltxt + "Entry : "  + str.tostring(math.round(close,        2)) + "\n"
    ltxt := ltxt + "Stop  : "  + str.tostring(math.round(long_stop,    2)) + "\n"
    ltxt := ltxt + "T1    : "  + str.tostring(math.round(long_t1,      2)) + "\n"
    ltxt := ltxt + "T2    : "  + str.tostring(math.round(long_t2,      2)) + "\n"
    ltxt := ltxt + "T3    : "  + str.tostring(math.round(long_t3,      2)) + "\n"
    ltxt := ltxt + "Size  : "  + str.tostring(math.round(long_size,    4)) + " units\n"
    ltxt := ltxt + "Risk$ : $" + str.tostring(math.round(risk_dollars, 2)) + "\n"
    ltxt := ltxt + "Score : "  + str.tostring(long_confluence) + "/8\n"
    ltxt := ltxt + "Vol   : "  + vol_regime
    label.new(bar_index, low - atr_val, ltxt, color=color.new(color.green, 10), textcolor=color.white, style=label.style_label_up, size=size.normal)

if i_showLabels and short_rr_valid
    string stxt = "🔴 GEDE4 SHORT\n"
    stxt := stxt + "Entry : "  + str.tostring(math.round(close,        2)) + "\n"
    stxt := stxt + "Stop  : "  + str.tostring(math.round(short_stop,   2)) + "\n"
    stxt := stxt + "T1    : "  + str.tostring(math.round(short_t1,     2)) + "\n"
    stxt := stxt + "T2    : "  + str.tostring(math.round(short_t2,     2)) + "\n"
    stxt := stxt + "T3    : "  + str.tostring(math.round(short_t3,     2)) + "\n"
    stxt := stxt + "Size  : "  + str.tostring(math.round(short_size,   4)) + " units\n"
    stxt := stxt + "Risk$ : $" + str.tostring(math.round(risk_dollars, 2)) + "\n"
    stxt := stxt + "Score : "  + str.tostring(short_confluence) + "/8\n"
    stxt := stxt + "Vol   : "  + vol_regime
    label.new(bar_index, high + atr_val, stxt, color=color.new(color.red, 10), textcolor=color.white, style=label.style_label_down, size=size.normal)

if squeeze_off
    label.new(bar_index, bb_lower - atr_val * 0.5, "⚡ SQUEEZE\nRELEASED",
              color=color.new(color.purple, 10),
              textcolor=color.white,
              style=label.style_label_up,
              size=size.small)

// ─────────────────────────────────────────────────────────────
// SECTION 10 — GEDE4 INTELLIGENCE PANEL
// ─────────────────────────────────────────────────────────────

c_bull   = color.new(color.lime,  0)
c_bear   = color.new(color.red,   0)
c_neut   = color.new(color.gray,  0)
c_warn   = color.new(color.orange,0)
c_bg2    = color.new(#0a1628,     0)
c_header = color.new(#0d2137,     0)
c_gold   = color.new(#C9A84C,     0)

tf_str = str.tostring(timeframe.period)

var table panel = table.new(
     position     = position.top_right,
     columns      = 3,
     rows         = 28,
     bgcolor      = c_bg2,
     border_color = color.new(color.teal, 60),
     border_width = 1,
     frame_color  = color.new(color.teal, 30),
     frame_width  = 2)

if i_showTable and barstate.islast
    table.cell(panel, 0, 0, "⚡ GEDE4 INTELLIGENCE",   text_color=c_gold, bgcolor=c_header, text_size=size.normal, text_halign=text.align_left)
    table.cell(panel, 1, 0, syminfo.ticker,             text_color=c_gold, bgcolor=c_header, text_size=size.normal)
    table.cell(panel, 2, 0, tf_str + " · cryptolwa.io", text_color=c_neut, bgcolor=c_header, text_size=size.small,  text_halign=text.align_right)

    table.cell(panel, 0, 1, "MOMENTUM", text_color=color.white, bgcolor=color.new(color.navy, 30), text_size=size.small)
    table.cell(panel, 1, 1, "VALUE",    text_color=color.white, bgcolor=color.new(color.navy, 30), text_size=size.small)
    table.cell(panel, 2, 1, "SIGNAL",   text_color=color.white, bgcolor=color.new(color.navy, 30), text_size=size.small)

    table.cell(panel, 0, 2, "RSI(" + str.tostring(i_rsiLen) + ")", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 2, str.tostring(math.round(rsi, 1)),      text_color=rsi_bull ? c_bull : rsi_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 2, rsi_bull ? "OVERSOLD ▲" : rsi_bear ? "OVERBOUGHT ▼" : "NEUTRAL", text_color=rsi_bull ? c_bull : rsi_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 3, "MACD", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 3, str.tostring(math.round(macdHist, 4)), text_color=macd_hist_rising ? c_bull : macd_hist_falling ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 3, macd_bull ? "CROSS UP ▲" : macd_bear ? "CROSS DN ▼" : macd_hist_rising ? "HIST ▲" : "HIST ▼", text_color=(macd_bull or macd_hist_rising) ? c_bull : c_bear, text_size=size.small)

    table.cell(panel, 0, 4, "STOCH %K", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 4, str.tostring(math.round(stoch_k, 1)), text_color=stoch_bull ? c_bull : stoch_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 4, stoch_bull ? "CROSS UP ▲" : stoch_bear ? "CROSS DN ▼" : "–", text_color=stoch_bull ? c_bull : stoch_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 5, "CCI(" + str.tostring(i_cciLen) + ")", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 5, str.tostring(math.round(cci, 1)), text_color=cci_bull ? c_bull : cci_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 5, cci_bull ? "EXTREME LOW ▲" : cci_bear ? "EXTREME HIGH ▼" : "–", text_color=cci_bull ? c_bull : cci_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 6, "Williams %R", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 6, str.tostring(math.round(willR, 1)), text_color=will_bull ? c_bull : will_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 6, will_bull ? "OVERSOLD ▲" : will_bear ? "OVERBOUGHT ▼" : "–", text_color=will_bull ? c_bull : will_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 7, "ROC(" + str.tostring(i_rocLen) + ")", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 7, str.tostring(math.round(roc, 3)), text_color=roc_bull ? c_bull : roc_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 7, roc_bull ? "ACCEL ▲" : roc_bear ? "DECEL ▼" : "FLAT", text_color=roc_bull ? c_bull : roc_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 8, "MOM SCORE", text_color=c_neut, text_size=size.small, text_font_family=font.family_monospace)
    table.cell(panel, 1, 8, str.tostring(mom_score) + " / ±6", text_color=mom_score >= 2 ? c_bull : mom_score <= -2 ? c_bear : c_warn, text_size=size.small)
    table.cell(panel, 2, 8, mom_score >= 3 ? "🔥 STRONG BULL" : mom_score <= -3 ? "🧊 STRONG BEAR" : mom_score >= 1 ? "MILD BULL" : mom_score <= -1 ? "MILD BEAR" : "MIXED", text_color=mom_score >= 2 ? c_bull : mom_score <= -2 ? c_bear : c_warn, text_size=size.small)

    table.cell(panel, 0, 9, "VOLATILITY", text_color=color.white, bgcolor=color.new(color.purple, 40), text_size=size.small)
    table.cell(panel, 1, 9, "",           bgcolor=color.new(color.purple, 40))
    table.cell(panel, 2, 9, "",           bgcolor=color.new(color.purple, 40))

    table.cell(panel, 0, 10, "BB Width", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 10, str.tostring(math.round(bb_width * 100, 2)) + "%", text_color=c_neut, text_size=size.small)
    table.cell(panel, 2, 10, bb_width < bb_width_avg * 0.7 ? "🟣 SQUEEZE" : bb_width > bb_width_avg * 1.5 ? "EXPANSION" : "NORMAL", text_color=squeeze_on ? color.new(color.purple, 0) : c_neut, text_size=size.small)

    table.cell(panel, 0, 11, "ATR(" + str.tostring(i_atrLen) + ")", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 11, str.tostring(math.round(atr_val, 4)), text_color=c_neut, text_size=size.small)
    table.cell(panel, 2, 11, "Pctile: " + str.tostring(math.round(vol_pctile, 0)) + "%", text_color=vol_pctile > 75 ? c_warn : c_neut, text_size=size.small)

    table.cell(panel, 0, 12, "BB Squeeze", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 12, squeeze_on ? "ON (" + str.tostring(squeeze_count) + " bars)" : "OFF", text_color=squeeze_on ? color.new(color.purple, 0) : c_neut, text_size=size.small)
    table.cell(panel, 2, 12, vol_regime, text_color=vol_pctile > 75 ? c_warn : vol_pctile < 25 ? c_bull : c_neut, text_size=size.small)

    table.cell(panel, 0, 13, "VOLUME", text_color=color.white, bgcolor=color.new(color.teal, 40), text_size=size.small)
    table.cell(panel, 1, 13, "",       bgcolor=color.new(color.teal, 40))
    table.cell(panel, 2, 13, "",       bgcolor=color.new(color.teal, 40))

    table.cell(panel, 0, 14, "OBV vs SMA", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 14, obv_bull ? "ABOVE" : "BELOW", text_color=obv_bull ? c_bull : c_bear, text_size=size.small)
    table.cell(panel, 2, 14, obv_bull ? "ACCUMULATE ▲" : "DISTRIBUTE ▼", text_color=obv_bull ? c_bull : c_bear, text_size=size.small)

    table.cell(panel, 0, 15, "MFI(" + str.tostring(i_mfiLen) + ")", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 15, str.tostring(math.round(mfi, 1)), text_color=mfi_bull ? c_bull : mfi_bear ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 15, mfi_bull ? "OVERSOLD ▲" : mfi_bear ? "OVERBOUGHT ▼" : "–", text_color=mfi_bull ? c_bull : mfi_bear ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 16, "VWAP", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 16, str.tostring(math.round(vwap_val, 2)), text_color=above_vwap ? c_bull : c_bear, text_size=size.small)
    table.cell(panel, 2, 16, above_vwap ? "PRICE ABOVE ▲" : "PRICE BELOW ▼", text_color=above_vwap ? c_bull : c_bear, text_size=size.small)

    table.cell(panel, 0, 17, "CVD Proxy", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 17, cvd_bull ? "NET BUYING" : "NET SELLING", text_color=cvd_bull ? c_bull : c_bear, text_size=size.small)
    table.cell(panel, 2, 17, vol_spike ? "⚡ VOL SPIKE" : vol_dry ? "💤 LOW VOL" : "NORMAL", text_color=vol_spike ? c_warn : vol_dry ? c_bear : c_neut, text_size=size.small)

    table.cell(panel, 0, 18, "VOL SCORE", text_color=c_neut, text_size=size.small, text_font_family=font.family_monospace)
    table.cell(panel, 1, 18, str.tostring(vol_score) + " / ±4", text_color=vol_score >= 2 ? c_bull : vol_score <= -2 ? c_bear : c_warn, text_size=size.small)
    table.cell(panel, 2, 18, vol_score >= 3 ? "💪 STRONG FLOW" : vol_score <= -3 ? "⚠️ WEAK FLOW" : "MODERATE", text_color=vol_score >= 2 ? c_bull : vol_score <= -2 ? c_bear : c_warn, text_size=size.small)

    table.cell(panel, 0, 19, "🎯 GEDE4 SIGNAL", text_color=color.white, bgcolor=color.new(color.maroon, 10), text_size=size.small)
    table.cell(panel, 1, 19, "",                bgcolor=color.new(color.maroon, 10))
    table.cell(panel, 2, 19, "",                bgcolor=color.new(color.maroon, 10))

    table.cell(panel, 0, 20, "HTF Bias", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 20, htf_bias,   text_color=htf_uptrend ? c_bull : htf_downtrend ? c_bear : c_warn, text_size=size.small)
    table.cell(panel, 2, 20, i_htfTrend + " timeframe", text_color=c_neut, text_size=size.small, text_halign=text.align_right)

    table.cell(panel, 0, 21, "LONG Score", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 21, str.tostring(long_confluence) + " / 8", text_color=long_confluence >= i_minConfluence ? c_bull : c_neut, text_size=size.small)
    table.cell(panel, 2, 21, long_confluence >= i_minConfluence ? "✅ ENTRY VALID" : "⏳ WATCHING", text_color=long_confluence >= i_minConfluence ? c_bull : c_neut, text_size=size.small)

    table.cell(panel, 0, 22, "SHORT Score", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 22, str.tostring(short_confluence) + " / 8", text_color=short_confluence >= i_minConfluence ? c_bear : c_neut, text_size=size.small)
    table.cell(panel, 2, 22, short_confluence >= i_minConfluence ? "✅ ENTRY VALID" : "⏳ WATCHING", text_color=short_confluence >= i_minConfluence ? c_bear : c_neut, text_size=size.small)

    signal_txt = long_rr_valid ? "🟢 GO LONG" : short_rr_valid ? "🔴 GO SHORT" : "⚪ STANDBY"
    signal_col = long_rr_valid ? c_bull      : short_rr_valid ? c_bear      : c_neut
    table.cell(panel, 0, 23, "DECISION", text_color=color.white, text_size=size.normal, text_font_family=font.family_monospace)
    table.cell(panel, 1, 23, signal_txt, text_color=signal_col,   text_size=size.normal)
    table.cell(panel, 2, 23, "Min RR 1:" + str.tostring(i_minRR), text_color=c_neut, text_size=size.small, text_halign=text.align_right)

    entry_val = long_rr_valid ? close      : short_rr_valid ? close      : na
    stop_val  = long_rr_valid ? long_stop  : short_rr_valid ? short_stop : na
    t1_val    = long_rr_valid ? long_t1    : short_rr_valid ? short_t1   : na
    size_val  = long_rr_valid ? long_size  : short_rr_valid ? short_size : na

    table.cell(panel, 0, 24, "Entry / Stop / T1", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 24, not na(entry_val) ? str.tostring(math.round(entry_val, 2)) + " / " + str.tostring(math.round(stop_val, 2)) : "–", text_color=c_gold, text_size=size.small)
    table.cell(panel, 2, 24, not na(t1_val)    ? "T1: " + str.tostring(math.round(t1_val, 2)) : "–", text_color=c_gold, text_size=size.small)

    table.cell(panel, 0, 25, "Position Size", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 25, not na(size_val) ? str.tostring(math.round(size_val, 4)) + " units" : "–", text_color=c_gold, text_size=size.small)
    table.cell(panel, 2, 25, "Risk: $" + str.tostring(math.round(risk_dollars, 2)), text_color=c_warn, text_size=size.small)

    table.cell(panel, 0, 26, "→ Lasirèn",       text_color=color.new(color.teal,  0), text_size=size.small)
    table.cell(panel, 1, 26, "cryptolwa.io",    text_color=color.new(color.teal, 20), text_size=size.small)
    table.cell(panel, 2, 26, "Capital: $" + str.tostring(math.round(i_accountSize, 0)), text_color=c_neut, text_size=size.small, text_halign=text.align_right)

    div_txt = (bull_div_rsi ? "RSI Bull " : "") + (bull_div_obv ? "OBV Bull " : "") + (bear_div_rsi ? "RSI Bear " : "") + (bear_div_obv ? "OBV Bear " : "")
    table.cell(panel, 0, 27, "Divergences", text_color=c_neut, text_size=size.small)
    table.cell(panel, 1, 27, str.length(div_txt) > 0 ? div_txt : "None detected", text_color=str.length(div_txt) > 0 ? c_warn : c_neut, text_size=size.small)
    table.cell(panel, 2, 27, squeeze_off ? "⚡ SQUEEZE FIRED" : squeeze_on ? "🟣 COILING (" + str.tostring(squeeze_count) + ")" : "–", text_color=squeeze_off ? c_gold : squeeze_on ? color.new(color.purple, 0) : c_neut, text_size=size.small)

// ─────────────────────────────────────────────────────────────
// SECTION 11 — SIGNAL PLOTS
// ─────────────────────────────────────────────────────────────

plotshape(long_rr_valid,                "GEDE4 Long Signal",  shape.arrowup,   location.belowbar, color.lime,  size=size.normal)
plotshape(short_rr_valid,               "GEDE4 Short Signal", shape.arrowdown, location.abovebar, color.red,   size=size.normal)
plotshape(squeeze_off,                  "Squeeze Release",     shape.diamond,   location.belowbar, color.yellow,size=size.small)
plotshape(bull_div_rsi or bull_div_obv, "Bull Divergence",     shape.circle,    location.belowbar, color.new(color.teal,   30), size=size.tiny)
plotshape(bear_div_rsi or bear_div_obv, "Bear Divergence",     shape.circle,    location.abovebar, color.new(color.orange, 30), size=size.tiny)

// ─────────────────────────────────────────────────────────────
// SECTION 12 — ALERTS (top-level; gated by input)
// ─────────────────────────────────────────────────────────────
// Webhook JSON payload — feeds the Lasirèn bridge /signal endpoint.
// TradingView substitutes {{ticker}} and {{time}} automatically.

long_alert_msg = '{"agent":"GEDE4","action":"long","symbol":"{{ticker}}","entry":' + str.tostring(close, "#.########") +
                 ',"stop":'  + str.tostring(close - atr_val * i_atrStopMult, "#.########") +
                 ',"tp1":'   + str.tostring(close + (atr_val * i_atrStopMult) * i_minRR, "#.########") +
                 ',"score":' + str.tostring(long_confluence) +
                 ',"vol":"'  + vol_regime + '","htf":"' + htf_bias + '","tf":"' + tf_str + '","time":"{{time}}"}'

short_alert_msg = '{"agent":"GEDE4","action":"short","symbol":"{{ticker}}","entry":' + str.tostring(close, "#.########") +
                  ',"stop":'  + str.tostring(close + atr_val * i_atrStopMult, "#.########") +
                  ',"tp1":'   + str.tostring(close - (atr_val * i_atrStopMult) * i_minRR, "#.########") +
                  ',"score":' + str.tostring(short_confluence) +
                  ',"vol":"'  + vol_regime + '","htf":"' + htf_bias + '","tf":"' + tf_str + '","time":"{{time}}"}'

squeeze_alert_msg = '{"agent":"GEDE4","action":"squeeze_release","symbol":"{{ticker}}","bars":' + str.tostring(squeeze_count) + ',"vol":"' + vol_regime + '","mom":' + str.tostring(mom_score) + ',"time":"{{time}}"}'

alertcondition(long_rr_valid  and i_alertsOn, "GEDE4 Long Entry",         "🟢 GEDE4 LONG · cryptolwa.io")
alertcondition(short_rr_valid and i_alertsOn, "GEDE4 Short Entry",        "🔴 GEDE4 SHORT · cryptolwa.io")
alertcondition(squeeze_off    and i_alertsOn, "GEDE4 Squeeze Release",    "⚡ GEDE4 SQUEEZE FIRED · cryptolwa.io")
alertcondition(bull_div_rsi   and i_alertsOn, "GEDE4 RSI Bull Divergence","🔵 RSI Bull Divergence · cryptolwa.io")
alertcondition(bear_div_rsi   and i_alertsOn, "GEDE4 RSI Bear Divergence","🟠 RSI Bear Divergence · cryptolwa.io")
alertcondition(bull_div_obv   and i_alertsOn, "GEDE4 OBV Bull Divergence","💚 OBV Bull Divergence · cryptolwa.io")
alertcondition(bear_div_obv   and i_alertsOn, "GEDE4 OBV Bear Divergence","🟧 OBV Bear Divergence · cryptolwa.io")
alertcondition(vwap_reclaim   and i_alertsOn, "GEDE4 VWAP Reclaim",       "📈 VWAP Reclaim · cryptolwa.io")
alertcondition(vwap_reject    and i_alertsOn, "GEDE4 VWAP Rejection",     "📉 VWAP Reject · cryptolwa.io")

// alert() — dynamic webhook payloads. Set TradingView alert to
// "Any alert() function call" to receive the structured JSON.
if long_rr_valid  and i_alertsOn
    alert(long_alert_msg,    alert.freq_once_per_bar_close)
if short_rr_valid and i_alertsOn
    alert(short_alert_msg,   alert.freq_once_per_bar_close)
if squeeze_off    and i_alertsOn
    alert(squeeze_alert_msg, alert.freq_once_per_bar_close)

// ─────────────────────────────────────────────────────────────
// END OF GEDE4 (Pine v6)
// Capital preserved. Lasirèn notified. The market is read.
// ─────────────────────────────────────────────────────────────
