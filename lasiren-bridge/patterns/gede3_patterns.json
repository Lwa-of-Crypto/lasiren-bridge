    { "id": "harmonic_gartley",        "name": "Gartley",                 "category": "Harmonic",     "duration_min": 20, "duration_max": 200, "atr_min": 1.5, "atr_max": 50, "entry": "d_point",        "stop_atr": 1.5, "target_mult": [0.382, 0.618, 1.0] },
