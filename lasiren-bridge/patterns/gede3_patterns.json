    { "id": "rsi_divergence",          "name": "RSI Divergence",          "category": "Momentum",     "duration_min": 8,  "duration_max": 60,  "atr_min": 0.5, "atr_max": 15, "entry": "confirmation",   "stop_atr": 1.5, "target_mult": [0.5, 1.0] }
