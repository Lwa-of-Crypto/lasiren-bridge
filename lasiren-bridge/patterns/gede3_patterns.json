{
  "metadata": {
    "name": "GEDE3 Pattern Library",
    "version": "1.0.0",
    "description": "50 chart patterns + per-pattern formation rules, lifecycle thresholds, and signal-generation defaults.",
    "retrain_cadence_days": 7
  },
  "globals": {
    "atr_period": 14,
    "default_timeframes": ["1m", "5m", "15m", "1h", "4h", "1d"],
    "account_risk_per_trade_pct": 0.5,
    "max_position_pct_per_asset": 5,
    "timeframe_priority": { "1d": 5, "4h": 4, "1h": 3, "15m": 2, "5m": 1, "1m": 0.5 },
    "emit_confidence_threshold": 0.6,
    "completion_stage_thresholds": { "beginning": 0.3, "middle": 0.8 },
    "slippage": { "pct": 0.0005, "min_price": 0.5 },
    "fees": { "maker_pct": 0.0002, "taker_pct": 0.0007 }
  },
  "patterns": [
    { "id": "ascending_triangle",      "name": "Ascending Triangle",      "category": "Continuation", "duration_min": 10, "duration_max": 200, "atr_min": 1.0, "atr_max": 60, "entry": "breakout_limit", "stop_atr": 2.0, "target_mult": [0.5, 1.0] },
    { "id": "descending_triangle",     "name": "Descending Triangle",     "category": "Continuation", "duration_min": 10, "duration_max": 200, "atr_min": 1.0, "atr_max": 60, "entry": "breakout_limit", "stop_atr": 2.0, "target_mult": [0.5, 1.0] },
    { "id": "symmetrical_triangle",    "name": "Symmetrical Triangle",    "category": "Continuation", "duration_min": 12, "duration_max": 200, "atr_min": 1.0, "atr_max": 50, "entry": "breakout_either", "stop_atr": 1.8, "target_mult": [0.5, 1.0] },
    { "id": "bull_flag",               "name": "Bull Flag",               "category": "Continuation", "duration_min": 5,  "duration_max": 60,  "atr_min": 0.5, "atr_max": 20, "entry": "retest_or_break", "stop_atr": 1.5, "target_mult": [0.6, 1.2] },
    { "id": "bear_flag",               "name": "Bear Flag",               "category": "Continuation", "duration_min": 5,  "duration_max": 60,  "atr_min": 0.5, "atr_max": 20, "entry": "retest_or_break", "stop_atr": 1.5, "target_mult": [0.6, 1.2] },
    { "id": "pennant",                 "name": "Pennant",                 "category": "Continuation", "duration_min": 5,  "duration_max": 30,  "atr_min": 0.5, "atr_max": 15, "entry": "breakout_either", "stop_atr": 1.5, "target_mult": [0.6, 1.2] },
    { "id": "rectangle_range",         "name": "Rectangle / Range",       "category": "Continuation", "duration_min": 15, "duration_max": 300, "atr_min": 1.5, "atr_max": 80, "entry": "breakout_either", "stop_atr": 1.5, "target_mult": [0.5, 1.0] },
    { "id": "cup_and_handle",          "name": "Cup and Handle",          "category": "Continuation", "duration_min": 30, "duration_max": 400, "atr_min": 2.0, "atr_max": 100,"entry": "breakout_limit", "stop_atr": 2.0, "target_mult": [0.5, 1.0] },
    { "id": "rising_channel",          "name": "Rising Channel",          "category": "Continuation", "duration_min": 20, "duration_max": 300, "atr_min": 1.0, "atr_max": 50, "entry": "channel_buy",     "stop_atr": 2.0, "target_mult": [0.5, 1.0] },
